using Xunit;

namespace MyApp.Tests;

public class UnitTest1
{
    [Fact]
    public void BasicTest_ShouldPass()
    {
        // Arrange
        int a = 5;
        int b = 3;

        // Act
        int result = a + b;

        // Assert
        Assert.Equal(8, result);
    }

    [Fact]
    public void StringTest_ShouldNotBeEmpty()
    {
        // Arrange
        string appName = "MyApp";

        // Assert
        Assert.False(string.IsNullOrEmpty(appName));
    }

    [Fact]
    public void MultiplyTest_ShouldPass()
    {
        // Arrange
        int a = 4;
        int b = 5;

        // Act
        int result = a * b;

        // Assert
        Assert.Equal(20, result);
    }
}
